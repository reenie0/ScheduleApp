@model ScheduleApp.Models.LoginViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="text-center">
    <h2 class="mb-4" style="color: #003300;">Login</h2>
</div>
<form asp-action="Login" method="post">
    <div class="form-group mb-3 row">
        <label asp-for="Email" class="col-sm-4 col-form-label text-end" style="color: #003300;">Email:</label>
        <div class="col-sm-8">
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
    </div>
    <div class="form-group mb-3 row">
        <label asp-for="Password" class="col-sm-4 col-form-label text-end" style="color: #003300;">Password:</label>
        <div class="col-sm-8">
            <input asp-for="Password" type="password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
    </div>
    <div class="form-group mb-3 row">
        <label asp-for="UserType" class="col-sm-4 col-form-label text-end" style="color: #003300;">User Type:</label>
        <div class="col-sm-8">
            <select asp-for="UserType" class="form-control">
                <option value="Student">Student</option>
                <option value="Lecturer">Lecturer</option>
            </select>
            <span asp-validation-for="UserType" class="text-danger"></span>
        </div>
    </div>
    <div class="form-group text-center">
        <button type="submit" class="btn btn-primary w-50">Login</button>
    </div>
</form>
